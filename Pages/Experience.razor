@page "/experience"

<div class="container py-3">
    <h2 class="border-bottom pb-2 mb-4">Professional Experience</h2>

    <div class="timeline position-relative ps-4 border-start border-2 border-secondary">
        @foreach (var job in WorkHistory)
        {
            <div class="mb-5 position-relative">
                <div class="position-absolute bg-primary rounded-circle" style="width: 12px; height: 12px; left: -31px; top: 6px;"></div>
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h4 class="mb-0 fw-bold text-dark">@job.Role</h4>
                    <span class="badge bg-secondary px-3 py-2 rounded-pill">@job.Duration</span>
                </div>
                <h5 class="text-primary mb-2">@job.Company</h5>
                <ul class="text-muted ps-3">
                    @foreach (var bullet in job.Highlights)
                    {
                        <li class="mb-1">@bullet</li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

@code {
    public class JobRecord
    {
        public string Role { get; set; } = string.Empty;
        public string Company { get; set; } = string.Empty;
        public string Duration { get; set; } = string.Empty;
        public List<string> Highlights { get; set; } = new();
    }

    private List<JobRecord> WorkHistory = new()
    {
